# ===== EJClaw Environment Configuration =====
# Copy this file to .env and fill in the values.
# Single unified service manages all three Discord bots in one process.

# --- Discord bots (3 tokens for 3 bots) ---
DISCORD_BOT_TOKEN=
DISCORD_CODEX_BOT_TOKEN=
DISCORD_REVIEW_BOT_TOKEN=

# --- Agent type configuration ---
OWNER_AGENT_TYPE=codex
REVIEWER_AGENT_TYPE=claude-code

# --- API keys ---
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_CODE_OAUTH_TOKENS=
GROQ_API_KEY=

# --- Bot identity ---
ASSISTANT_NAME=claude

# --- Claude model ---
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_EFFORT=high
CLAUDE_THINKING=adaptive

# --- Codex model ---
CODEX_MODEL=gpt-5.4
CODEX_EFFORT=xhigh

# --- Usage dashboard ---
STATUS_CHANNEL_ID=
USAGE_DASHBOARD=true
# STATUS_SHOW_ROOMS=true
# STATUS_SHOW_ROOM_DETAILS=false

# --- Fallback provider (when Claude/Codex both unavailable) ---
# FALLBACK_ENABLED=true
# FALLBACK_PROVIDER_NAME=kimi
# FALLBACK_BASE_URL=
# FALLBACK_AUTH_TOKEN=
# FALLBACK_MODEL=kimi-k2.5
# FALLBACK_SMALL_MODEL=kimi-k2.5
# FALLBACK_COOLDOWN_MS=600000

# --- Per-role model overrides (paired rooms) ---
# OWNER_MODEL=gpt-5.4
# OWNER_EFFORT=xhigh
# OWNER_FALLBACK_ENABLED=true
# REVIEWER_MODEL=claude-opus-4-6
# REVIEWER_EFFORT=high
# REVIEWER_FALLBACK_ENABLED=true
# ARBITER_MODEL=claude-sonnet-4-6
# ARBITER_EFFORT=high
# ARBITER_FALLBACK_ENABLED=true

# --- Mixture of Agents (MoA) ---
# MOA_ENABLED=true
# MOA_REF_MODELS=kimi,glm
# MOA_KIMI_MODEL=kimi-k2.5
# MOA_KIMI_BASE_URL=https://api.kimi.com/coding
# MOA_KIMI_API_KEY=
# MOA_GLM_MODEL=glm-4-plus
# MOA_GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# MOA_GLM_API_KEY=

# --- Advanced ---
# MAX_CONCURRENT_AGENTS=5
# SESSION_COMMAND_ALLOWED_SENDERS=

# --- Remote worker control plane ---
REMOTE_WORKER_CONTROL_PLANE_ENABLED=true
REMOTE_WORKER_CONTROL_PLANE_HOST=127.0.0.1
REMOTE_WORKER_CONTROL_PLANE_PORT=8787
REMOTE_WORKER_CONTROL_PLANE_TOKEN=replace-with-shared-secret
